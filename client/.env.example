# Browser -> FastAPI base URL.
# Local dev:
NEXT_PUBLIC_RAG_API_URL=http://localhost:8000
# Production (Vercel): set to your Fly app, e.g.
# NEXT_PUBLIC_RAG_API_URL=https://dog-breed-rag.fly.dev

# Optional server-side (SSR) fallback; usually the same value.
RAG_API_URL=http://localhost:8000

# NOTE: Never put secrets behind NEXT_PUBLIC_* — those are shipped to the browser.
# LiveKit tokens are minted server-side by the API (/api/voice/session).
