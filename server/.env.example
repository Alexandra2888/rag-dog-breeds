# --- Database (Postgres + pgvector) ---
# Host port 5433 matches docker-compose (maps 5433 -> container 5432).
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ragdb

# --- Inference provider ---
# "ollama" (default, local dev) or "openai" (any OpenAI-compatible API).
INFERENCE_PROVIDER=ollama

# Local: Ollama (used when INFERENCE_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.1:8b

# Cloud free deploy: Google Gemini via its OpenAI-compatible endpoint
# (one free key from https://aistudio.google.com does chat + 768-dim embeddings).
# Used when INFERENCE_PROVIDER=openai.
INFERENCE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
INFERENCE_API_KEY=
INFERENCE_CHAT_MODEL=gemini-2.5-flash
# Embeddings via Jina (separate provider; generous free tier, 768-dim).
# Free key at https://jina.ai/embeddings. Falls back to INFERENCE_* if unset.
INFERENCE_EMBEDDING_BASE_URL=https://api.jina.ai/v1
INFERENCE_EMBEDDING_API_KEY=
INFERENCE_EMBEDDING_MODEL=jina-embeddings-v2-base-en
INFERENCE_EMBEDDING_DIM=0

# --- Chunking (fallback size chunking only; breed-aware chunking is automatic) ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Voice (optional: only needed for the LiveKit voice agent) ---
# LiveKit Cloud uses wss://<project>.livekit.cloud; local server uses ws://localhost:7880
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_PORT=8080

# Required for voice speech-to-text and text-to-speech (OpenAI).
OPENAI_API_KEY=
