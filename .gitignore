# Environment — ignore all .env variants (incl. .env.prod, .env.local),
# but keep the committed .env.example templates.
**/.env
**/.env.*
!**/.env.example

# Node / Next.js
node_modules/
client/.next/
client/out/
client/build/
*.tsbuildinfo
next-env.d.ts

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# OS / editor
.DS_Store
*.log
